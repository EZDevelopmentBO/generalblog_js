{
  "name": "tradersworld-blog-backend",
  "version": "1.0.0",
  "description": "Backend API para blog de traders (criptos, metales, acciones, forex)",
  "engines": {
    "node": ">=24"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "migrate": "node -r ts-node/register -e \"require('./src/config/runMigrations').run()\"",
    "create-post": "ts-node src/scripts/create-post-from-json.ts",
    "promote-superuser": "ts-node src/scripts/promote-superuser.ts",
    "delete-user": "ts-node src/scripts/delete-user-by-email.ts"
  },
  "dependencies": {
    "bootstrap-icons": "^1.13.1",
    "connect-pg-simple": "^9.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "groq-sdk": "^0.5.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.12.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.5.0",
    "@types/nodemailer": "^7.0.9",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pg": "^8.11.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
