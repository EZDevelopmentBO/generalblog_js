# =============================================================================
# backend/.env.example — copia a .env y rellena (nunca subas .env con secretos)
# Variables leídas por backend/src/config/env.ts salvo indicación contraria.
# =============================================================================

# -----------------------------------------------------------------------------
# Node (no está en env.ts; lo usa Express/Node)
# -----------------------------------------------------------------------------
# Entorno de ejecución: en producción suele ser "production" (menos logs, etc.)
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Base de datos (obligatorio para datos reales)
# -----------------------------------------------------------------------------
# URL de conexión PostgreSQL (única BD del proyecto).
#
# Usa UNA línea DATABASE_URL según dónde corre el backend y Postgres:
#
# 1) docker compose up (backend + db en la misma red Docker) — el host es `db`,
#    usuario/clave/bd coinciden con docker-compose.yml (POSTGRES_* del servicio db):
DATABASE_URL=postgresql://blog:blog_secret@db:5432/blog
#
# 2) npm run dev en tu PC y Postgres en localhost:5432:
# DATABASE_URL=postgresql://usuario:clave@localhost:5432/nombre_base
#
# 3) Backend en contenedor y Postgres solo en tu máquina (no el servicio db):
#    Mac/Win Docker Desktop: host.docker.internal. Linux: IP del host o extra_hosts.
# DATABASE_URL=postgresql://usuario:clave@host.docker.internal:5432/nombre_base

# -----------------------------------------------------------------------------
# Servidor HTTP y URLs públicas
# -----------------------------------------------------------------------------
# Puerto donde escucha el API Express.
PORT=4000

# URL base del API tal como la ven clientes y enlaces en emails (sin barra final).
API_URL=http://localhost:4000

# Origen del frontend: CORS, cookies de sesión y redirects tras login/pagos.
# Debe coincidir con la URL real del navegador (ej. https://tudominio.com).
FRONTEND_URL=http://localhost:5173

# Si defines esta ruta (ruta al build de Vite), el backend sirve el SPA y puede
# inyectar meta Open Graph en HTML para crawlers en URLs de posts.
# Ejemplo desde backend/: FRONTEND_DIST=../frontend/dist
FRONTEND_DIST=

# Zona horaria IANA para fechas en títulos/contenido de posts (por defecto UTC).
# Ejemplo: America/La_Paz
SITE_TIMEZONE=UTC-4

# -----------------------------------------------------------------------------
# Sesión (cookies firmadas)
# -----------------------------------------------------------------------------
# Secreto largo y aleatorio en producción; firma la cookie de sesión.
SESSION_SECRET=cambia-esto-en-produccion-minimo-32-caracteres

# -----------------------------------------------------------------------------
# Google OAuth (login con Google en el sitio)
# -----------------------------------------------------------------------------
# Credenciales de la pantalla de consentimiento en Google Cloud Console.
# Si quedan vacías, el login con Google no estará disponible.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# LLM — borradores de posts desde el admin (opcional)
# -----------------------------------------------------------------------------
# Proveedor: "groq" (por defecto) o "siliconflow".
LLM_PROVIDER=groq

# Groq (https://console.groq.com/) — clave API para generar texto.
GROQ_API_KEY=
# Modelo Groq si quieres otro distinto al predeterminado del código.
GROQ_MODEL=llama-3.3-70b-versatile

# SiliconFlow — solo si LLM_PROVIDER=siliconflow
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=Qwen/QwQ-32B

# -----------------------------------------------------------------------------
# PayPal (pagos y webhooks)
# -----------------------------------------------------------------------------
# Credenciales de la app PayPal (sandbox o live según PAYPAL_MODE).
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox | live
PAYPAL_MODE=sandbox
# ID del webhook en el panel PayPal (notificaciones de pago al backend).
PAYPAL_WEBHOOK_ID=

# -----------------------------------------------------------------------------
# Binance Pay (checkout merchant Binance Pay)
# -----------------------------------------------------------------------------
# Claves de la aplicación Binance Pay.
BINANCE_PAY_API_KEY=
BINANCE_PAY_SECRET_KEY=
# URL de la API (casi siempre la predeterminada).
BINANCE_PAY_BASE_URL=https://bpay.binanceapi.com
# true = modo simulado en local (sin red real; útil para desarrollo).
BINANCE_PAY_SANDBOX=true
# PEM público para verificar firma del webhook (opcional; sin esto no se verifica).
BINANCE_PAY_WEBHOOK_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Binance — depósitos / transferencia USDT (API de wallet, solo lectura recomendada)
# -----------------------------------------------------------------------------
# Para comprobar depósitos a tu wallet: API key con permiso "Enable Reading" únicamente.
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# Red de la dirección de depósito (ej. BEP20, ERC20, TRON).
BINANCE_DEPOSIT_NETWORK=BEP20

# =============================================================================
# Solo scripts (no usadas por env.ts en el servidor normal)
# =============================================================================
# create-post-from-json.ts: ID numérico del usuario autor del post importado.
# AUTHOR_ID=1
